---
import AppShell from "../../../layouts/AppShell.astro";
import AvMiniAppBar from "../../../components/AvMiniAppBar.astro";
import { server, getDictionaryEntryDetail } from "../../../actions";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const entryId = Number(Astro.params.id);
if (!Number.isFinite(entryId)) {
  return new Response("Invalid entry id", { status: 400 });
}

const formData = Astro.request.method === "POST" ? await Astro.request.formData() : null;
let flash: { type: "success" | "error"; message: string } | null = null;

if (formData) {
  try {
    const intent = String(formData.get("intent") ?? "");
    if (intent === "favorite") await Astro.callAction(server.toggleDictionaryEntryFavorite, { id: entryId });
    if (intent === "archive") await Astro.callAction(server.archiveDictionaryEntry, { id: entryId });
    if (intent === "restore") await Astro.callAction(server.restoreDictionaryEntry, { id: entryId });
    flash = { type: "success", message: "Entry updated." };
  } catch (error) {
    flash = { type: "error", message: error instanceof Error ? error.message : "Unable to update entry." };
  }
}

let entry;
try {
  entry = await getDictionaryEntryDetail(entryId, user.id);
} catch {
  return new Response("Entry not found", { status: 404 });
}
---

<AppShell title={`${entry.term} | Dictionary+`}>
  <AvMiniAppBar appName="Dictionary+" appKey="dictionary-plus" />

  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/app" class="text-sm text-indigo-300 hover:text-indigo-200">← Back to workspace</a>

    {flash && <p class={`mt-4 rounded-xl border px-4 py-3 text-sm ${flash.type === "success" ? "border-emerald-800 bg-emerald-950 text-emerald-200" : "border-rose-800 bg-rose-950 text-rose-200"}`}>{flash.message}</p>}

    <article class="mt-4 rounded-3xl border border-slate-800 bg-slate-900 p-6 sm:p-8">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-white">{entry.term}</h1>
          <p class="mt-1 text-sm text-slate-400">{entry.phonetic || "No phonetic"} · {entry.partOfSpeech || "Part of speech not set"}</p>
        </div>
        <div class="flex gap-2">
          <form method="POST"><input type="hidden" name="intent" value="favorite" /><button class="rounded-lg border border-slate-700 px-3 py-1.5 text-sm text-slate-200">{entry.isFavorite ? "★ Favorited" : "☆ Favorite"}</button></form>
          {entry.status === "active" ? (
            <form method="POST"><input type="hidden" name="intent" value="archive" /><button class="rounded-lg border border-amber-800 px-3 py-1.5 text-sm text-amber-200">Archive</button></form>
          ) : (
            <form method="POST"><input type="hidden" name="intent" value="restore" /><button class="rounded-lg border border-emerald-800 px-3 py-1.5 text-sm text-emerald-200">Restore</button></form>
          )}
        </div>
      </div>

      <section class="mt-7 space-y-6">
        <div>
          <h2 class="text-xs uppercase tracking-[0.14em] text-slate-400">Definition</h2>
          <p class="mt-2 text-lg leading-8 text-slate-100">{entry.definition}</p>
        </div>
        {entry.exampleText && (
          <div>
            <h2 class="text-xs uppercase tracking-[0.14em] text-slate-400">Usage example</h2>
            <p class="mt-2 rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-slate-200">{entry.exampleText}</p>
          </div>
        )}
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <h2 class="text-xs uppercase tracking-[0.14em] text-slate-400">Category</h2>
            <p class="mt-2 text-slate-200">{entry.category || "Uncategorized"}</p>
          </div>
          <div>
            <h2 class="text-xs uppercase tracking-[0.14em] text-slate-400">Status</h2>
            <p class="mt-2 text-slate-200">{entry.status}</p>
          </div>
        </div>
        {entry.notes && (
          <div>
            <h2 class="text-xs uppercase tracking-[0.14em] text-slate-400">Notes</h2>
            <p class="mt-2 whitespace-pre-wrap text-slate-200">{entry.notes}</p>
          </div>
        )}
      </section>

      <footer class="mt-8 border-t border-slate-800 pt-4 text-xs text-slate-400">
        <p>Created: {new Date(entry.createdAt).toLocaleString()}</p>
        <p class="mt-1">Last updated: {new Date(entry.updatedAt).toLocaleString()}</p>
      </footer>
    </article>
  </main>
</AppShell>
