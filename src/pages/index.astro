---
import AppShell from "../layouts/AppShell.astro";
import AvMiniAppBar from "../components/AvMiniAppBar.astro";

const title = "Dictionary+ | Personal Dictionary Workspace";
const description = "Build and organize your personal dictionary with premium clarity inside Ansiversa.";
---

<AppShell title={title} description={description}>
  <AvMiniAppBar appName="Dictionary+" appKey="dictionary-plus" />

  <main class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8">
    <section class="rounded-3xl border border-slate-800 bg-gradient-to-b from-slate-900 to-slate-950 p-8 sm:p-12">
      <p class="text-sm uppercase tracking-[0.16em] text-indigo-300">Ansiversa Mini App</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">Your private dictionary, designed for deep learning.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-slate-300">
        Dictionary+ helps you capture terms, definitions, examples, and notes in one polished workspace. Organize by category, mark favorites, and archive entries while keeping your study history intact.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/app" class="rounded-xl bg-indigo-500 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-400">Open Workspace</a>
        <a href="#features" class="rounded-xl border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 hover:text-white">Explore Features</a>
      </div>
    </section>

    <section id="features" class="mt-10 grid gap-4 sm:grid-cols-2">
      {[
        ["Structured word capture", "Save term, phonetic spelling, part of speech, definitions, and context in one place."],
        ["Focused organization", "Use categories and favorites to surface the words you revisit most."],
        ["Archive with confidence", "Move inactive terms out of the way without deleting your history."],
        ["Ansiversa connected", "Dashboard summary and key milestones sync into the parent experience."],
      ].map(([title, body]) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
          <h2 class="text-lg font-medium text-white">{title}</h2>
          <p class="mt-2 text-sm leading-6 text-slate-300">{body}</p>
        </article>
      ))}
    </section>
  </main>
</AppShell>
